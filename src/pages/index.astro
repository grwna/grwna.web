---
import "@/styles/global.css";
import Navbar from "@/components/islands/Navbar.tsx";
import { Button } from "@/components/ui/button.tsx";
import profileData from "@/content/hero/profile.json";

import skillsData from "@/content/skills/skills.json";
import toolsData from "@/content/tools/tools.json";
import experiencesData from "@/content/experiences/experiences.json";
import projectsData from "@/content/projects/projects.json";
import writingData from "@/content/writing/writing.json";

import { SkillCard } from "@/components/islands/SkillCard";
import { ToolPill } from "@/components/islands/ToolPill";
import { ExperienceCard } from "@/components/islands/ExperienceCard";
import { ProjectCard } from "@/components/islands/ProjectCard";
import { WritingCard } from "@/components/islands/WritingCard";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Grwna's Site</title>
        <script is:inline>
            const theme = (() => {
              if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                return localStorage.getItem('theme');
              }
              if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                return 'dark';
              }
              return 'light';
            })();
            if (theme === 'light') {
              document.documentElement.classList.remove('dark');
            } else {
              document.documentElement.classList.add('dark');
            }
          </script>
	</head>
	<body class="min-h-[100vh]">
        <Navbar client:load />
        <main class="flex flex-col items-center w-full pt-[80px]">
            {/* Hero */}
            <section id="profile" class="hero flex flex-col-reverse md:flex-row items-center justify-between pb-20 pt-10 gap-10 px-6 md:px-20 min-h-[calc(100vh-80px)] w-full max-w-7xl">
                <div class="flex-1 flex flex-col items-center md:items-start text-center md:text-left">
                    <h2 class="text-4xl md:text-6xl font-bold text-foreground leading-tight m-0">
                        {profileData.greeting}
                    </h2>
                    <h3 class="text-2xl mt-3 font-heading text-primary">{profileData.subtitle}</h3>
                    
                    <div class="mt-4 flex flex-col gap-2">
                        {profileData.paragraphs.map(paragraph => (
                            <p class="text-base md:text-lg text-muted-foreground leading-relaxed">{paragraph}</p>
                        ))}
                    </div>
                    <div class="mt-8 flex gap-4">
                        <a href="#projects" class="no-underline">
                            <Button variant="firmo" size="firmo" className="cursor-pointer">View Projects</Button>
                        </a>
                        <a href="#writing" class="no-underline">
                             <Button variant="outline" size="firmo" className="cursor-pointer rounded-2xl">Read Writing</Button>
                        </a>
                    </div>
                </div>
                <div class="flex-1 flex justify-center md:justify-end">
                     <img src={profileData.image} alt="Profile" class="w-full max-w-sm rounded-[3rem] shadow-2xl border-4 border-primary/20 hover:scale-[1.02] transition-transform duration-500" />
                </div>
            </section>

            {/* Skills */}
            <section id="skills" class="centered-section w-full max-w-7xl">
                <h2 class="section-title">My Skills</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {skillsData.map(skill => (
                        <SkillCard {...skill} client:visible />
                    ))}
                </div>
            </section>

            {/* Tools */}
            <section id="tools" class="centered-section w-full max-w-7xl">
                <h2 class="section-title">Tools I Use</h2>
                <div class="flex flex-wrap gap-4">
                    {toolsData.map(tool => (
                        <ToolPill {...tool} client:visible />
                    ))}
                </div>
            </section>

            {/* Experience */}
            <section id="experience" class="centered-section w-full max-w-7xl">
                <h2 class="section-title">Experience</h2>
                <div class="flex flex-col gap-6">
                    {experiencesData.map(exp => (
                        <ExperienceCard {...exp} client:visible />
                    ))}
                </div>
            </section>

            {/* Projects */}
            <section id="projects" class="centered-section w-full max-w-7xl">
                <h2 class="section-title">Projects I've Done</h2>
                <div class="flex flex-col gap-8">
                    {projectsData.map(project => (
                        <ProjectCard {...project} client:visible />
                    ))}
                </div>
            </section>

            {/* Writing */}
            <section id="writing" class="centered-section w-full max-w-7xl mb-20">
                <h2 class="section-title">My Writing</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    {writingData.map(write => (
                        <WritingCard {...write} client:visible />
                    ))}
                </div>
            </section>
        </main>
	</body>
</html>
