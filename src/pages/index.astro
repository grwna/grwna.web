---
import "@/styles/global.css";
import Navbar from "@/components/islands/Navbar.tsx";
import { Button } from "@/components/ui/button.tsx";
import profileData from "@/content/hero/profile.json";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Grwna's Site</title>
        <script is:inline>
            const theme = (() => {
              if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                return localStorage.getItem('theme');
              }
              if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                return 'dark';
              }
              return 'light';
            })();
            if (theme === 'light') {
              document.documentElement.classList.remove('dark');
            } else {
              document.documentElement.classList.add('dark');
            }
          </script>
	</head>
	<body class="min-h-[100vh]">
        <Navbar client:load />
        <main class="flex flex-col items-center w-full pt-[80px]">
            {/* Hero */}
            <section class="hero flex flex-col-reverse md:flex-row items-center justify-between pb-20 pt-10 gap-10 px-6 md:px-20 min-h-[calc(100vh-80px)] w-full max-w-7xl">
                <div class="flex-1 flex flex-col items-center md:items-start text-center md:text-left">
                    <h2 class="text-4xl md:text-6xl font-bold text-foreground leading-tight m-0">
                        {profileData.greeting}
                    </h2>
                    <h3 class="text-2xl mt-3 font-heading text-primary">{profileData.subtitle}</h3>
                    
                    <div class="mt-4 flex flex-col gap-2">
                        {profileData.paragraphs.map(paragraph => (
                            <p class="text-base md:text-lg text-muted-foreground">{paragraph}</p>
                        ))}
                    </div>
                </div>
                <div class="flex-1 flex justify-center md:justify-end">
                     <img src={profileData.image} alt="Profile" class="w-full max-w-sm rounded-[2rem] shadow-xl border-4 border-border" />
                </div>
            </section>

            <section class="min-h-screen flex items-center justify-center w-full bg-accent/30 px-6">
                <h2 class="text-4xl md:text-6xl text-center font-bold text-foreground leading-tight m-0">
                    THIS SITE IS A WORK IN PROGRESS
                </h2>
            </section>

            {/* Experience */}
            <section id="featured-projects" class="centered-section">
                <h2 class="section-title">Professional Experience</h2>
                <div class="flex flex-col">
                    <div class="empty-placeholder">
                        <p>No Experience to show here...</p>
                    </div>
                </div>
            </section>

            {/* Projects */}
            <section id="projects" class="centered-section">
                <h2 class="section-title">Projects</h2>
                <div>
                    <div class="empty-placeholder pb-40">
                        <p>No Projects to show here...</p>
                    </div>
                </div>
            </section>

            {/* Volunteering */}
            <section id="featured-projects" class="centered-section">
                <h2 class="section-title">Volunteering</h2>
                <div class="flex flex-col">
                    <div class="empty-placeholder">
                        <p>Nothing to show here...</p>
                    </div>
                </div>
            </section>
        </main>
	</body>
</html>
